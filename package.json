{
  "name": "nextjs-playground",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenvx run -- next dev",
    "dev:3100": "dotenvx run -- bash -c 'PORT=3100 next dev'",
    "build": "dotenvx run -- next build",
    "build:analyze": "dotenvx run -- bash -c 'ANALYZE=true next build'",
    "build:ci": "dotenvx run -- bash -c 'CI=true NEXT_PUBLIC_CI=true next build'",
    "check": "tsc --noEmit",
    "check:build": "dotenvx run -- bash -c 'tsc --noEmit && next build'",
    "transpile": "tsc --outDir .transpiled --declaration",
    "transpile:ci": "dotenvx run -- bash -c 'tsc --noEmit && CI=true NEXT_PUBLIC_CI=true next build'",
    "start": "dotenvx run -- next start",
    "start:3100": "dotenvx run -- bash -c 'PORT=3100 next start'",
    "lint": "biome lint --write",
    "lint:check": "biome lint",
    "format": "biome format --write .",
    "format:check": "biome format",
    "check:biome": "biome check --write",
    "check:biome:ci": "biome check",
    "test": "dotenvx run -- vitest --watch=false",
    "test:db": "dotenvx run -- vitest src/__tests__/database/setup.test.ts src/__tests__/database/seed.test.ts src/__tests__/database/schema.test.ts",
    "test:ui": "dotenvx run -- vitest --ui --exclude src/__tests__/database/seed.test.ts",
    "test:coverage": "dotenvx run -- vitest --coverage --exclude src/__tests__/database/seed.test.ts",
    "e2e": "dotenvx run -- playwright test",
    "e2e:debug": "dotenvx run -- playwright test --debug",
    "e2e:ui": "dotenvx run -- playwright test --ui",
    "prisma:studio": "dotenvx run -- prisma studio",
    "azurite:start": "bash scripts/start-azurite.sh",
    "azurite:stop": "bash scripts/stop-azurite.sh",
    "blob:monitor": "bash scripts/monitor-blob-events.sh",
    "db:init": "prisma init",
    "db:migrate": "dotenvx run -- prisma migrate dev",
    "db:seed": "dotenvx run -- tsx src/lib/seed.ts",
    "db:verify": "dotenvx run -- tsx verify-database.ts",
    "blob:watch": "bash scripts/watch-dir-upsert.sh",
    "dotenvx:encrypt": "dotenvx encrypt",
    "dotenvx:decrypt": "dotenvx decrypt",
    "dotenvx:keys:generate": "dotenvx keys generate",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.1",
    "@dotenvx/dotenvx": "^1.54.1",
    "@libsql/client": "0.8.1",
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@tanstack/react-query": "^5.90.20",
    "dotenv": "^17.2.3",
    "next": "16.1.5",
    "react": "19.2.4",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prisma": "^7.3.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "pnpm": ">=10.18.2"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "biome check --write"
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a"
}